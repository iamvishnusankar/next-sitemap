{
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "postbuild": {
      "dependsOn": ["build", "^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "public/robots.txt",
        "public/sitemap*.xml"
      ]
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false
    }
  }
}
